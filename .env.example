# 국가법령정보센터 API 설정
# https://open.law.go.kr에서 API 키 발급 후 입력하세요
LAW_API_KEY=your_api_key_here

# (선택사항) 로깅 레벨
# LOG_LEVEL=INFO

# (선택사항) HTTP 서버 모드 활성화
# HTTP_MODE=1

# (선택사항) HTTP 서버 포트 (기본값: 8096)
# PORT=8096

# (선택사항) 국가법령정보센터 API 기본 URL (변경 불필요)
# LAW_API_URL=https://www.law.go.kr/DRF

# (선택사항) SSL 인증서 검증 설정
# LAW_SSL_VERIFY=true

# (선택사항) 커스텀 CA 인증서 경로
# LAW_CA_BUNDLE=/path/to/ca-bundle.crt

# (선택사항) OS 인증서 저장소 사용 (truststore 설치 필요)
# LAW_USE_TRUSTSTORE=false
